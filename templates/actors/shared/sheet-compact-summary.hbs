<div class="compact-summary">
    <div class="compact-summary-aptitudes">
        {{#each document.system.aptitudes as |attr key|}}
        <div class="compact-summary-aptitude">
            <div class="compact-summary-input" style="display:flex; align-items:center; justify-content:center;">{{attr.total}}</div>
            <label class="compact-summary-label">{{localize attr.label}}</label>
            <div class="compact-summary-aptitude-values" style="display:flex; align-items:center; justify-content:center; gap:8px; font-size:11px; line-height:1; margin-top:3px;">
                <label>{{localize "BREAK.Base"}}:
                    <input name="system.aptitudes.{{key}}.value" type="number" value="{{attr.value}}" placeholder="0" style="width:34px; text-align:center;"/>
                </label>
                <span>{{localize "BREAK.BonPen"}}: {{attr.bon}}</span>
            </div>
            <div class="compact-summary-aptitude-row">
                <div class="compact-summary-bar-track">
                    <div class="compact-summary-bar-fill" style="background: {{attr.color}}; width: {{mul attr.total 5 precision=2}}%;"></div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>

    <div class="compact-summary-combat">
        <div class="compact-summary-stat">
            <div class="compact-summary-stat-top">
                <span class="compact-summary-stat-icon"><i class="fas fa-sword"></i></span>
                <div class="compact-summary-stat-input" style="display:flex; align-items:center; justify-content:center;">{{document.system.attack.total}}</div>
            </div>
            <label class="compact-summary-label">{{localize "BREAK.Attack"}}</label>
            <div class="compact-summary-stat-values" style="display:flex; align-items:center; justify-content:center; gap:8px; font-size:11px; line-height:1; margin-top:3px;">
                <label>{{localize "BREAK.Base"}}:
                    <input name="system.attack.value" type="number" value="{{document.system.attack.value}}" placeholder="0" style="width:34px; text-align:center;"/>
                </label>
                <span>{{localize "BREAK.BonPen"}}: {{document.system.attack.bon}}</span>
            </div>
        </div>

        <div class="compact-summary-stat">
            <div class="compact-summary-stat-top">
                <span class="compact-summary-stat-icon compact-summary-heart"><i class="fas fa-heart"></i></span>
                <input
                    name="system.hearts.value"
                    type="number"
                    class="compact-summary-stat-input"
                    value="{{document.system.hearts.value}}"
                    placeholder="0"
                />
                <span class="compact-summary-stat-separator">/</span>
                <div class="compact-summary-stat-input" style="display:flex; align-items:center; justify-content:center;">{{document.system.hearts.total}}</div>
            </div>
            <label class="compact-summary-label">{{localize "BREAK.Hearts"}}</label>
            <div class="compact-summary-stat-values" style="display:flex; align-items:center; justify-content:center; gap:8px; font-size:11px; line-height:1; margin-top:3px;">
                <label>{{localize "BREAK.Base"}}:
                    <input name="system.hearts.max" type="number" value="{{document.system.hearts.max}}" placeholder="0" style="width:34px; text-align:center;"/>
                </label>
                <span>{{localize "BREAK.BonPen"}}: {{document.system.hearts.bon}}</span>
            </div>
        </div>

        <div class="compact-summary-stat">
            <div class="compact-summary-stat-top">
                <span class="compact-summary-stat-icon"><i class="fas fa-shield"></i></span>
                <div class="compact-summary-stat-input" style="display:flex; align-items:center; justify-content:center;">{{document.system.defense.total}}</div>
            </div>
            <label class="compact-summary-label">{{localize "BREAK.Defense"}}</label>
            <div class="compact-summary-stat-values" style="display:flex; align-items:center; justify-content:center; gap:8px; font-size:11px; line-height:1; margin-top:3px;">
                <label>{{localize "BREAK.Base"}}:
                    <input name="system.defense.value" type="number" value="{{document.system.defense.value}}" placeholder="0" style="width:34px; text-align:center;"/>
                </label>
                <span>{{localize "BREAK.BonPen"}}: {{document.system.defense.bon}}</span>
            </div>
        </div>

        <div class="compact-summary-stat">
            <div class="compact-summary-stat-top">
                <span class="compact-summary-stat-icon"><i class="fas fa-person-running"></i></span>
                <div class="compact-summary-stat-input" style="display:flex; align-items:center; justify-content:center;">{{document.system.speed.total}}</div>
            </div>
            <label class="compact-summary-label">{{localize "BREAK.Speed"}}</label>
            <div class="compact-summary-stat-values" style="display:flex; align-items:center; justify-content:center; gap:8px; font-size:11px; line-height:1; margin-top:3px;">
                <label>{{localize "BREAK.Base"}}:
                    <select name="system.speed.value" style="max-width:82px;">
                        <option value="0" {{#when document.system.speed.value 'eq' 0}}selected="selected"{{/when}}>{{localize "BREAK.SLOW"}}</option>
                        <option value="1" {{#when document.system.speed.value 'eq' 1}}selected="selected"{{/when}}>{{localize "BREAK.AVERAGE"}}</option>
                        <option value="2" {{#when document.system.speed.value 'eq' 2}}selected="selected"{{/when}}>{{localize "BREAK.FAST"}}</option>
                        <option value="3" {{#when document.system.speed.value 'eq' 3}}selected="selected"{{/when}}>{{localize "BREAK.VFAST"}}</option>
                    </select>
                </label>
                <span>{{localize "BREAK.BonPen"}}: {{document.system.speed.bon}}</span>
            </div>
        </div>
    </div>
</div>
