<section style="display:flex;flex-direction:column;height:100%;min-height:0;">
    <div style="flex:1;min-height:0;overflow-y:auto;padding-right:6px;display:flex;flex-direction:column;">
        <div class="form-group">
            <label>{{localize "BREAK.Name"}}</label>
            <input type="text" name="name" value="{{action.name}}">
        </div>

        <div style="display:flex;width:100%;column-gap:12px;">
            <div class="form-group" style="width: 50%;">
                <label>{{localize "BREAK.RollType"}}</label>
                <select name="rollType" class="roll-type-select">
                {{#each rollTypes as |type key|}}
                    <option value="{{type.key}}" {{#if (eq type.key ../action.rollType)}}selected{{/if}}>
                    {{localize type.label}}
                    </option>
                {{/each}}
                </select>
            </div>
            <div class="form-group aptitude-select" style="width:50%;display: none;">
                <label>{{localize "BREAK.Aptitude"}}</label>
                <select name="aptitude">
                {{#each aptitudes as |aptitude key|}}
                    <option value="{{aptitude.key}}" {{#if (eq aptitude.key ../action.aptitude)}}selected{{/if}}>
                    {{localize aptitude.label}}
                    </option>
                {{/each}}
                </select>
            </div>
            <div class="form-group vs-select" style="width:50%;display: none;">
                <label>{{localize "BREAK.VS"}}</label>
                <select name="vs">
                {{#each aptitudes as |aptitude key|}}
                    <option value="{{aptitude.key}}" {{#if (eq aptitude.key ../action.vs)}}selected{{/if}}>
                    {{localize aptitude.label}}
                    </option>
                {{/each}}
                </select>
            </div>
            <div class="form-group check-trigger-select" style="width:50%;display: none;">
                <label>{{localize "BREAK.ACTION.CheckEffectTrigger"}}</label>
                <select name="checkEffectTrigger">
                {{#each checkEffectTriggers as |trigger key|}}
                    <option value="{{trigger.key}}" {{#if (eq trigger.key ../action.checkEffectTrigger)}}selected{{/if}}>
                    {{localize trigger.label}}
                    </option>
                {{/each}}
                </select>
            </div>
        </div>
        
        <div class="flexrow" style="column-gap: 12px;">
            <div class="form-group">
                <label>{{localize "BREAK.ActionCost"}}</label>
                <select name="cost">
                {{#each costs as |cost key|}}
                    <option value="{{cost.key}}" {{#if (eq cost.key ../action.cost)}}selected{{/if}}>
                    {{localize cost.label}}
                    </option>
                {{/each}}
                </select>
            </div>

            <div class="form-group">
                <label>{{localize "BREAK.Target"}}</label>
                <select name="target">
                {{#each targets as |target key|}}
                    <option value="{{target.key}}" {{#if (eq target.key ../action.target)}}selected{{/if}}>
                    {{localize target.label}}
                    </option>
                {{/each}}
                </select>
            </div>
        </div>
        
        <div class="flexrow" style="column-gap: 12px;">
            <fieldset>
                <legend>{{localize "BREAK.ACTION.Requirements"}}</legend>
                <div class="form-group" data-fieldset="required">
                    <label>{{localize "TYPES.Item.item"}}</label>
                    <div class="action-item-drop" data-fieldset="required" style="display:flex;align-items:center;column-gap:8px;min-height:38px;">
                        {{#if action.requiredItemRef}}
                            <a class="item-link" style="cursor:pointer;" data-action="openReference">{{requiredItemLabel}}</a>
                            <a style="margin-left: auto;" data-action="clearReference"><i class="fas fa-xmark"></i></a>
                        {{else}}
                            <button type="button" class="select-feature" data-action="selectReference">{{localize "BREAK.PickOrDrag"}} {{localize "TYPES.Item.item"}}</button>
                        {{/if}}
                    </div>
                </div>
                <div style="display:flex;width:100%;column-gap:12px;">
                    <div class="form-group" style="width:50%;">
                        <label>{{localize "BREAK.Quantity"}}</label>
                        <input type="number" min="0" name="requiredItemQuantity" value="{{action.requiredItemQuantity}}">
                    </div>
                    <input type="hidden" name="requiredItemRef" value="{{action.requiredItemRef}}">
                    <input type="hidden" name="requiredItemName" value="{{action.requiredItemName}}">
                </div>
            </fieldset>

            <fieldset>
                <legend>{{localize "BREAK.ACTION.Costs"}}</legend>
                <div class="form-group" data-fieldset="consume">
                    <label>{{localize "TYPES.Item.item"}}</label>
                    <div class="action-item-drop" data-fieldset="consume" style="display:flex;align-items:center;column-gap:8px;min-height:38px;">
                        {{#if action.consumeItemRef}}
                            <a class="item-link" style="cursor:pointer;" data-action="openReference">{{consumeItemLabel}}</a>
                            <a style="margin-left: auto;" data-action="clearReference"><i class="fas fa-xmark"></i></a>
                        {{else}}
                            <button type="button" class="select-feature" data-action="selectReference">{{localize "BREAK.PickOrDrag"}} {{localize "TYPES.Item.item"}}</button>
                        {{/if}}
                    </div>
                </div>
                <div style="display:flex;width:100%;column-gap:12px;">
                    <div class="form-group" style="width:50%;">
                        <label>{{localize "BREAK.Quantity"}}</label>
                        <input type="number" min="0" name="consumeItemQuantity" value="{{action.consumeItemQuantity}}">
                    </div>
                    <input type="hidden" name="consumeItemRef" value="{{action.consumeItemRef}}">
                    <input type="hidden" name="consumeItemName" value="{{action.consumeItemName}}">
                </div>
            </fieldset>
        </div>

        <fieldset>
            <legend style="display:flex;align-items:center;">
                {{localize "BREAK.Effects"}}
                <a data-action="addActionEffect" style="margin-left:auto;"><i class="fa-regular fa-plus"></i></a>
            </legend>
            {{#each action.effects as |actionEffect|}}
            <div data-action-effect data-effect-id="{{actionEffect.id}}" style="display:flex;align-items:flex-end;column-gap:12px;border-bottom:1px dashed;margin-bottom:8px;padding-bottom:8px;">
                <div class="form-group" style="flex:1;margin-bottom:0;">
                    <label>{{localize "BREAK.Type"}}</label>
                    <select name="effectType" class="effect-type-select">
                    {{#each ../effects as |effect key|}}
                        <option value="{{effect.key}}" {{#if (eq effect.key actionEffect.type)}}selected{{/if}}>
                        {{localize effect.label}}
                        </option>
                    {{/each}}
                    </select>
                </div>
                <div class="form-group effect-amount-group" style="display:none;flex:0 0 120px;margin-bottom:0;">
                    <label>{{localize "BREAK.Amount"}}</label>
                    <input type="number" class="action-effect-amount" name="effectAmount" value="{{actionEffect.amount}}">
                </div>
                <div class="form-group effect-macro-group" style="display:none;flex:1;margin-bottom:0;">
                    <label>Macro</label>
                    <div class="action-macro-drop" style="display:flex;align-items:center;column-gap:8px;min-height:32px;border:1px dashed;padding:4px 6px;">
                        {{#if actionEffect.macroUuid}}
                            <span>{{actionEffect.macroName}}</span>
                            <a data-action="clearActionEffectMacro" style="margin-left:auto;"><i class="fas fa-xmark"></i></a>
                        {{else}}
                            <span>{{localize "BREAK.ACTION.MacroDropHint"}}</span>
                        {{/if}}
                    </div>
                    <input type="hidden" name="macroUuid" value="{{actionEffect.macroUuid}}">
                    <input type="hidden" name="macroName" value="{{actionEffect.macroName}}">
                </div>
                <a data-action="deleteActionEffect" style="flex:0 0 auto;margin-bottom:8px;"><i class="fas fa-trash"></i></a>
            </div>
            {{/each}}

            <div class="form-group">
                <label>{{localize "BREAK.ACTION.ActiveEffects"}}</label>
                <div class="action-active-effect-drop" style="display:flex;align-items:center;column-gap:8px;min-height:38px;border:1px dashed;padding:6px;">
                    {{localize "BREAK.ACTION.ActiveEffectDropHint"}}
                </div>
            </div>
            {{#if action.activeEffects.length}}
            <div style="display:flex;flex-direction:column;row-gap:6px;">
                {{#each action.activeEffects as |effect|}}
                <div data-active-effect-index="{{effect._actionIndex}}" data-active-effect-ref="{{effect._actionRef}}" style="display:flex;align-items:center;column-gap:8px;">
                    <img src="{{effect.img}}" style="width:24px;height:24px;border:0;">
                    <span>{{effect.name}}</span>
                    <a data-action="deleteActionActiveEffect" style="margin-left:auto;"><i class="fas fa-xmark"></i></a>
                </div>
                {{/each}}
            </div>
            {{/if}}
        </fieldset>
        
        <label>{{localize "BREAK.Description"}}</label>
        <div class="form-group" style="flex: 1;">
            <prose-mirror name="description" value="{{ action.description }}"></prose-mirror>
        </div>
    </div>

    <footer class="sheet-footer flexrow" style="flex:0 0 auto;margin-top:8px;">
        <button type="submit" class="dialog-button"><i class="fas fa-save"></i> Save</button>
    </footer>
</section>
