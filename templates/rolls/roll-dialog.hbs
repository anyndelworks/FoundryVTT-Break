<div class="break-roll-dialog" style="display:grid; grid-template-columns: {{#if aptitude}}repeat(3, minmax(150px, 1fr)){{else}}repeat(2, minmax(150px, 1fr)){{/if}}; gap:12px; min-width:{{#if aptitude}}520px{{else}}360px{{/if}};">
    {{#if aptitude}}
    <fieldset style="border:1px solid rgba(0,0,0,0.2); border-radius:6px; padding:10px; margin:0;gap: 0;">
        <legend style="font-weight:700; padding:0 4px;">{{localize "BREAK.RollType"}}</legend>
        <label style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:6px;">
            <span>{{localize "BREAK.Check"}}</span>
            <input name="rollType" type="radio" value="0" {{#if defaultCheck}}checked{{/if}} {{#if limited}}disabled{{/if}}/>
        </label>
        <label style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
            <span>{{localize "BREAK.Contest"}}</span>
            <input name="rollType" type="radio" value="1" {{#if defaultContest}}checked{{/if}} {{#if limited}}disabled{{/if}}/>
        </label>
    </fieldset>
    {{/if}}
    <fieldset style="border:1px solid rgba(0,0,0,0.2); border-radius:6px; padding:10px; margin:0;gap: 0;">
        <legend style="font-weight:700; padding:0 4px;">{{localize "BREAK.Edge"}}</legend>
        <label style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:6px;">
            <span>{{localize "BREAK.None"}}</span>
            <input name="edge" type="radio" value="" {{#unless defaultEdge}}checked{{/unless}} />
        </label>
        <label style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:6px;">
            <span>{{localize "BREAK.Edge"}}</span>
            <input name="edge" type="radio" value="1" {{#when defaultEdge 'eq' '1'}}checked{{/when}} />
        </label>
        <label style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
            <span>{{localize "BREAK.Snag"}}</span>
            <input name="edge" type="radio" value="2" {{#when defaultEdge 'eq' '2'}}checked{{/when}} />
        </label>
    </fieldset>
    <fieldset style="border:1px solid rgba(0,0,0,0.2); border-radius:6px; padding:10px; margin:0;gap: 0;">
        <legend style="font-weight:700; padding:0 4px;">{{localize "BREAK.Bonus"}}</legend>
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:6px 12px;">
            <div style="display:flex; flex-direction:column; row-gap:6px;">
                <label style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
                    <span>{{localize "BREAK.None"}}</span>
                    <input name="bonus" type="radio" value="" {{#unless defaultBonus}}checked{{/unless}} />
                </label>
                <label style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
                    <span>{{localize "BREAK.MinorBonus"}}</span>
                    <input name="bonus" type="radio" value="{{bonuses.MINOR_BONUS}}" {{#when defaultBonus 'eq' bonuses.MINOR_BONUS}}checked{{/when}} />
                </label>
                <label style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
                    <span>{{localize "BREAK.MajorBonus"}}</span>
                    <input name="bonus" type="radio" value="{{bonuses.MAJOR_BONUS}}" {{#when defaultBonus 'eq' bonuses.MAJOR_BONUS}}checked{{/when}} />
                </label>
            </div>
            <div style="display:flex; flex-direction:column; row-gap:6px;">
                <label style="display:flex; align-items:center; justify-content:space-between; gap:8px;margin-top:auto;">
                    <span>{{localize "BREAK.MinorPenalty"}}</span>
                    <input name="bonus" type="radio" value="{{bonuses.MINOR_PENALTY}}" {{#when defaultBonus 'eq' bonuses.MINOR_PENALTY}}checked{{/when}} />
                </label>
                <label style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
                    <span>{{localize "BREAK.MajorPenalty"}}</span>
                    <input name="bonus" type="radio" value="{{bonuses.MAJOR_PENALTY}}" {{#when defaultBonus 'eq' bonuses.MAJOR_PENALTY}}checked{{/when}} />
                </label>
            </div>
        </div>
        <input name="customBonus" placeholder="{{localize 'BREAK.CustomBonus'}}" style="width:100%; margin-top:10px;" type="number">
    </fieldset>
</div>
