{
  "id": "break",
  "version": "1.0",
  "title": "BREAK!!",
  "url": "https://github.com/Anyndol/FoundryVTT-Break",
  "manifest": "https://raw.githubusercontent.com/Anyndol/FoundryVTT-Break/dev/system.json",
  "download": "https://github.com/anyndelworks/FoundryVTT-Break/releases/download/v1.0/v1.0.zip",
  "description": "A BREAK!! TTRPG game system",
  "background": "systems/break/assets/headerimage.jpg",
  "license": "LICENSE",
  "authors": [
    {
      "name": "Anyndol"
    },
    {
      "name": "Valkyrie"
    },
    {
      "name": "Nicolasra"
    }
  ],
  "esmodules": ["break.js"],
  "styles": ["styles/break.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "es",
      "name": "Español",
      "path": "lang/es.json"
    }
  ],
  "packs": [
    {
      "name": "ailments",
      "label": "Ailments",
      "path": "packs/ailments",
      "type": "ActiveEffect"
    },
    {
      "name": "preview-content",
      "label": "BREAK!! Preview content",
      "path": "packs/preview-content",
      "type": "Item"
    },
    {
      "name": "preview-actors",
      "label": "BREAK!! Preview actors",
      "path": "packs/preview-actors",
      "type": "Actor"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": ["biography", "notes"]
      }
    }
  },
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "grid": {
    "distance": 1,
    "units": "area"
  },
  "primaryTokenAttribute": "hearts",
  "secondaryTokenAttribute": "power",
  "relationships": {
  "requires": [
    {
      "id": "break-shared-content",
      "type": "module",
      "compatibility": {
        "minimum": "1.0.0"
      }
    }
  ]
}
}
