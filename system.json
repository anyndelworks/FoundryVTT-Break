{
  "id": "break",
  "version": "1.0",
  "title": "BREAK!!",
  "url": "https://github.com/Anyndol/FoundryVTT-Break",
  "manifest": "https://raw.githubusercontent.com/Anyndol/FoundryVTT-Break/dev/system.json",
  "download": "https://github.com/anyndelworks/FoundryVTT-Break/releases/download/v1.0/v1.0.zip",
  "description": "A BREAK!! TTRPG game system",
  "background": "systems/break/assets/headerimage.jpg",
  "license": "LICENSE",
  "authors": [
    {
      "name": "Anyndol"
    },
    {
      "name": "Valkyrie"
    },
    {
      "name": "Nicolasra"
    }
  ],
  "esmodules": ["break.js"],
  "styles": ["styles/break.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "es",
      "name": "Español",
      "path": "lang/es.json"
    }
  ],
  "packs": [
    {
      "name": "ailments",
      "label": "Ailments",
      "path": "packs/ailments",
      "type": "ActiveEffect"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": ["biography", "description", "notes"]
      },
      "gmc": {
        "htmlFields": ["notes"]
      },
      "adversary": {
        "htmlFields": ["notes"]
      },
      "companion": {
        "htmlFields": ["notes"]
      }
    },
    "Item": {
      "accessory": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "armor": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "item": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "ammo": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "outfit": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "shield": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "calling": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "species": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "homeland": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "history": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "quirk": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "ability": {
        "htmlFields": ["description", "rules", "actions.*.description"]
      },
      "area-condition": {
        "htmlFields": ["description"]
      },
      "weapon": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "material": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "additive": {
        "htmlFields": ["description", "actions.*.description"]
      },
      "gift": {
        "htmlFields": ["description", "actions.*.description"]
      }
    }
  },
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "grid": {
    "distance": 1,
    "units": "area"
  },
  "primaryTokenAttribute": "hearts",
  "secondaryTokenAttribute": "power",
  "relationships": {
      "requires": [
      {
        "id": "break-shared-content",
        "type": "module",
        "compatibility": {
          "minimum": "1.0.0"
        }
      }
    ]
  }
}
